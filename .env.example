APP_NAME=WM Distribuidora API
APP_VERSION=0.1.0
API_V1_PREFIX=/api/v1
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3001,http://localhost:3005,http://localhost:8000

DB_HOST=localhost
DB_PORT=5432
DB_NAME=wm_distribuidora
DB_USER=wm_user
DB_PASSWORD=wm_password
DB_ECHO=false

SECRET_KEY=replace-with-a-secure-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_BASE_URL=https://api.mercadopago.com
MERCADOPAGO_WEBHOOK_SECRET=
MERCADOPAGO_NOTIFICATION_URL=
MERCADOPAGO_TIMEOUT_SECONDS=20

POSTGRES_DB=wm_distribuidora
POSTGRES_USER=wm_user
POSTGRES_PASSWORD=wm_password
